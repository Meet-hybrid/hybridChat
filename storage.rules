// storage.rules
// Deploy with: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Media files (images, video) for conversations
    match /media/{convoId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024   // 20MB max
        && (request.resource.contentType.matches('image/.*')
         || request.resource.contentType.matches('video/.*'));
    }

    // Voice notes
    match /audio/{convoId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;  // 10MB max
    }

    // File attachments (PDFs, docs)
    match /files/{convoId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024;  // 50MB max
    }
  }
}
