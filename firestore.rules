// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone logged in can read user profiles
      allow read: if request.auth != null;
      // Only the user themselves can write their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Conversations ─────────────────────────────────────────
    match /conversations/{convoId} {
      // Must be a member to read
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.members;

      // Must be a member to update (e.g. lastMessage)
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.members;

      // Any authenticated user can create a conversation
      // (they must include themselves as a member)
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.members;

      // ── Messages sub-collection ───────────────────────────
      match /messages/{msgId} {
        // Must be member of parent conversation to read/write
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convoId)).data.members;
      }
    }
  }
}
